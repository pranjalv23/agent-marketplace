# SECURITY: If .env was ever committed to git, rotate ALL of the following immediately:
#   1. AZURE_AI_FOUNDRY_API_KEY — regenerate in Azure portal
#   2. AUTH_JWT_SECRET       — changing this invalidates all active sessions
#   3. MONGO_URI credentials  — change password in MongoDB Atlas
#   4. INTERNAL_API_KEY       — change value and update all agent services

# LLM — embeddings for routing
AZURE_AI_FOUNDRY_ENDPOINT=https://<resource>.openai.azure.com/openai/v1
AZURE_AI_FOUNDRY_API_KEY=

# Agent URLs (Docker Compose internal service names)
FINANCIAL_AGENT_URL=http://agent-financials:8080
RESEARCH_AGENT_URL=http://agent-research:8081
INTERVIEW_PREP_AGENT_URL=http://agent-interview-prep:9003
NEWS_AGENT_URL=http://agent-news:9004
HEALTH_AGENT_URL=http://agent-health:9005

# Auth
AUTH_JWT_SECRET=        # REQUIRED: min 32 chars — openssl rand -hex 32
MONGO_URI=              # REQUIRED: MongoDB Atlas URI, e.g. mongodb+srv://user:pass@cluster/db
INTERNAL_API_KEY=       # openssl rand -hex 32

# Server
PORT=9000
ALLOWED_ORIGINS=https://your-frontend.pages.dev
LOG_LEVEL=INFO
